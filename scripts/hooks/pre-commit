#!/bin/sh
# Pre-commit hook: run critical tests + auto-bump semantic version.
# Blocks the commit if any test fails — especially domain separation.
#
# Version auto-bumps patch on every commit. Use [minor] or [major] in
# the commit message for bigger bumps (detected by commit-msg hook).
#
# To bypass in emergencies: git commit --no-verify
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit

echo "🔍 Running pre-commit tests..."

# Run the domain separation test (fast static analysis, ~2s)
python -m pytest tests/test_domain_separation.py -x --tb=short -q 2>&1
DOMAIN_EXIT=$?

if [ $DOMAIN_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Domain separation tests FAILED — commit blocked."
    echo "   Fix the queryKey/profile issues above before committing."
    echo "   (bypass with: git commit --no-verify)"
    exit 1
fi

# Run the security tests (fast, ~1s)
python -m pytest tests/test_security.py -x --tb=short -q 2>&1
SEC_EXIT=$?

if [ $SEC_EXIT -ne 0 ]; then
    echo ""
    echo "❌ Security tests FAILED — commit blocked."
    exit 1
fi

echo "✅ Pre-commit checks passed."

# --- Auto-bump semantic version -------------------------------------------
# Determine bump level from the commit message (passed via -m flag).
# The pre-commit hook doesn't have COMMIT_EDITMSG yet, so we parse the
# the commit message from the process command line.
BUMP="patch"
if [ -f .git/MERGE_MSG ]; then
    # Merge commits — don't bump
    exit 0
fi

# Check COMMIT_EDITMSG if it exists (interactive editor commits)
if [ -f .git/COMMIT_EDITMSG ]; then
    MSG=$(cat .git/COMMIT_EDITMSG)
    case "$MSG" in
        *\[major\]*) BUMP="major" ;;
        *\[minor\]*) BUMP="minor" ;;
    esac
fi

OLD_VERSION=$(cat VERSION 2>/dev/null || echo "0.0.0")
NEW_VERSION=$(python scripts/bump_version.py "$BUMP" 2>&1)
BUMP_EXIT=$?

if [ $BUMP_EXIT -ne 0 ]; then
    echo "⚠️  Version bump failed: $NEW_VERSION"
else
    echo "📦 Version: $OLD_VERSION → $NEW_VERSION ($BUMP)"
    git add VERSION
    if [ -f dashboard/frontend/package.json ]; then
        git add dashboard/frontend/package.json
    fi
fi

exit 0
